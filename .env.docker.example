# ============================================================
# PDF Chat Application - Docker Self-Hosted Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit this file to version control

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://postgres:YOUR_SECURE_PASSWORD@postgres:5432/pdf_chat
DB_PASSWORD=YOUR_SECURE_PASSWORD

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://:YOUR_SECURE_PASSWORD@redis:6379
REDIS_PASSWORD=YOUR_SECURE_PASSWORD

# ============================================================
# Qdrant Vector Database Configuration
# ============================================================
QDRANT_URL=http://qdrant:6333

# ============================================================
# Storage Configuration (Local Filesystem)
# ============================================================
STORAGE_PATH=/data/uploads
NEXT_PUBLIC_UPLOAD_URL=/uploads

# ============================================================
# Application Configuration
# ============================================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================
# Authentication Configuration
# ============================================================
NEXTAUTH_SECRET=YOUR_RANDOM_SECRET_KEY_HERE
NEXTAUTH_URL=http://localhost

# Generate a secure secret with: openssl rand -base64 32

# ============================================================
# Supabase Configuration (Optional - for authentication)
# ============================================================
# If you want to use Supabase for authentication, fill these in:
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# AI Model API Keys
# ============================================================
# Choose your AI model provider:

# Alibaba Qwen (Recommended for Chinese)
ALIBABA_API_KEY=your_alibaba_api_key
QWEN_API_KEY=your_qwen_api_key

# Or OpenAI (for English)
# OPENAI_API_KEY=your_openai_api_key

# ============================================================
# Email Configuration (Optional - for password reset)
# ============================================================
# SMTP settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# Or use Resend (recommended)
RESEND_API_KEY=your_resend_api_key

# ============================================================
# Rate Limiting Configuration
# ============================================================
# Guest user limits
GUEST_DAILY_LIMIT=3

# Authenticated user limits
USER_DAILY_LIMIT=50
USER_MONTHLY_LIMIT=500

# ============================================================
# Performance Tuning
# ============================================================
# Maximum file size (in bytes)
MAX_FILE_SIZE=104857600  # 100MB

# Cache duration (in seconds)
CACHE_TTL=3600  # 1 hour

# ============================================================
# Monitoring & Logging
# ============================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# ============================================================
# Security Headers
# ============================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost

# CSP (Content Security Policy)
NEXT_PUBLIC_CSP=*

# ============================================================
# Feature Flags
# ============================================================
# Enable/disable features
ENABLE_OCR=true
ENABLE_PDF_PAGINATION=true
ENABLE_CONVERSATION_HISTORY=true
ENABLE_USER_PREFERENCES=true
