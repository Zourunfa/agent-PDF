# Qwen (通义千问) API Configuration
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v2

# Voyage AI for Claude-compatible embeddings
# Use Voyage AI embeddings as alternative to Qwen embeddings
VOYAGE_API_KEY=sk-your-voyage-api-key-here

# Alternative: OpenAI API Configuration
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Upstash Redis Configuration
# Required for Vercel deployment to cache PDF data across serverless instances
#
# When using Vercel + Upstash integration, these env vars are auto-provided:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# For local development or manual setup, use:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob Storage (Optional - for PDF file persistence)
BLOB_READ_WRITE_TOKEN=

# File Upload Configuration
MAX_FILE_SIZE=10485760
TEMP_DIR=/tmp/pdf-chat

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Logging
LOG_LEVEL=debug
