# Qwen (通义千问) API Configuration
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v2

# Voyage AI for Claude-compatible embeddings
# Use Voyage AI embeddings as alternative to Qwen embeddings
VOYAGE_API_KEY=sk-your-voyage-api-key-here

# Alternative: OpenAI API Configuration
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Pinecone Vector Database Configuration (推荐)
# 用于持久化向量存储，跨实例共享
# 免费版：1个索引，100K向量，足够个人项目
# 获取 API Key: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=pdf-chat

# Upstash Redis Configuration
# 用于存储 PDF 元数据和文本内容（不再存储向量）
#
# When using Vercel + Upstash integration, these env vars are auto-provided:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
#
# For local development or manual setup, use:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob Storage (Optional - for PDF file persistence)
BLOB_READ_WRITE_TOKEN=

# Admin Configuration (管理员凭证)
# 只有管理员可以访问用户管理页面
ADMIN_USERNAME=admin
ADMIN_PASSWORD=aa123321

# Supabase Configuration (用户认证和数据库)
# 获取方式：https://supabase.com/dashboard
# 1. 创建新项目
# 2. 在 Settings > API 中获取以下信息
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MailerSend Email Configuration (邮件服务 - 推荐)
# 支持 GitHub OAuth 注册，免费 3000 封/月
# 1. 访问 https://www.mailersend.com/ 注册（可用 GitHub 登录）
# 2. 在 API Tokens 中创建 API Token（需要 email.send 权限）
# 3. 在 Sender Domains 中验证域名或邮箱
MAILERSEND_API_KEY=your-mailersend-api-key-here
MAILERSEND_SENDER_EMAIL=noreply@yourdomain.com
MAILERSEND_SENDER_NAME=PDF AI Chat

# File Upload Configuration
MAX_FILE_SIZE=10485760
TEMP_DIR=/tmp/pdf-chat

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Logging
LOG_LEVEL=debug
